# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=your_api_key_here

# Model to use for evaluation (haiku is cheapest)
EVAL_MODEL=claude-haiku-4-5-20251001

# Model to use as LLM judge (can be same or different)
JUDGE_MODEL=claude-haiku-4-5-20251001

# Similarity threshold for semantic judge (0.0 - 1.0)
SIMILARITY_THRESHOLD=0.75

# Score threshold for LLM judge (0.0 - 1.0)
LLM_JUDGE_THRESHOLD=0.7
